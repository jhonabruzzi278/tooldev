---
import '@/styles/global.css';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import SEOHead from '@/components/shared/SEOHead.astro';
import type { Locale } from '@/lib/i18n/translations';
import ChatIA from '@/components/shared/ChatIA';
import interLatin from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  locale?: Locale;
}

const { title, description, ogImage, locale = 'es' } = Astro.props;
---

<html lang={locale === 'en' ? 'en' : 'es'} class="scroll-smooth">
  <head>
    <SEOHead {title} {description} {ogImage} {locale} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href={interLatin} as="font" type="font/woff2" crossorigin />
    <link rel="preconnect" href="https://api.svgl.app" />
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "ToolDev",
      "url": "https://tool-dev-rust.vercel.app",
      "description": "Tu guía de herramientas para desarrollo",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "jonathanguerra278@gmail.com",
        "contactType": "customer service"
      }
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-primary focus:text-primary-foreground focus:rounded-lg focus:shadow-lg">
      {locale === 'en' ? 'Skip to main content' : 'Saltar al contenido principal'}
    </a>
    <Header locale={locale} />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
    <ChatIA client:load />
  </body>
</html>
