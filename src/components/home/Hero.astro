---
import { Button } from '@/components/ui/button';
---

<section class="py-20 md:py-32">
  <div class="container mx-auto px-4 text-center">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">
      Encuentra la herramienta adecuada
      <br />
      <span class="text-muted-foreground">para tu próximo proyecto.</span>
    </h1>
    <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto mb-8">
      Guías, alternativas y recomendaciones reales para desarrolladores.
    </p>
    <Button asChild size="lg">
      <a href="/tools">Explorar herramientas</a>
    </Button>
  </div>
</section>
