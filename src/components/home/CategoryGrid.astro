---
import { Card, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { categories } from '@/lib/categories';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');

const categoriesWithCount = categories.map((cat) => ({
  ...cat,
  count: tools.filter((t) => t.data.category === cat.slug).length,
}));
---

<section class="py-16 bg-muted/50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">Categorías</h2>
      <p class="text-muted-foreground">Explora herramientas por área de especialización</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {categoriesWithCount.map((cat) => (
        <a href={`/categories/${cat.slug}`}>
          <Card class="h-full hover:shadow-lg transition-shadow cursor-pointer">
            <CardHeader>
              <CardTitle class="flex items-center gap-2">
                {cat.name}
              </CardTitle>
              <CardDescription>
                {cat.description}
              </CardDescription>
              <p class="text-sm font-medium text-primary mt-2">
                {cat.count} {cat.count === 1 ? 'herramienta' : 'herramientas'}
              </p>
            </CardHeader>
          </Card>
        </a>
      ))}
    </div>
  </div>
</section>
