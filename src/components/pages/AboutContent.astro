---
import { Icon } from 'astro-icon/components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { categories } from '@/lib/categories';
import { getTranslations } from '@/lib/i18n/translations';
import type { Locale } from '@/lib/i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'es' } = Astro.props;
const lang = getTranslations(locale);

const tools = await getCollection('tools');
const openSourceCount = tools.filter((t) => t.data.openSource).length;
const freeCount = tools.filter((t) => t.data.pricing === 'gratis' || t.data.pricing === 'open-source').length;

const reasons = [
  { title: locale === 'es' ? 'Curación real' : 'Real curation', desc: lang.aboutReasons.curation, icon: 'tabler:filter-check' },
  { title: locale === 'es' ? 'Explicaciones prácticas' : 'Practical explanations', desc: lang.aboutReasons.practical, icon: 'tabler:bulb' },
  { title: locale === 'es' ? 'Alternativas útiles' : 'Useful alternatives', desc: lang.aboutReasons.alternatives, icon: 'tabler:git-compare' },
  { title: locale === 'es' ? 'Enfoque para desarrolladores' : 'Developer focus', desc: lang.aboutReasons.devFocus, icon: 'tabler:users' },
  { title: locale === 'es' ? 'Contenido en español' : 'Spanish content', desc: lang.aboutReasons.spanish, icon: 'tabler:language' },
];
---

<BaseLayout title={locale === 'en' ? 'About' : 'Acerca de'} description={locale === 'en' ? 'Learn about ToolDev, your reference for discovering developer tools.' : 'Conoce ToolDev, tu referencia para descubrir herramientas de desarrollo.'} {locale}>
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-4 max-w-2xl text-center">
      <p class="text-xs uppercase tracking-widest text-muted-foreground mb-4">{lang.about.badge}</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        {lang.about.title} <span class="text-primary">{lang.about.titleGradient}</span>
      </h1>
      <p class="text-base text-muted-foreground leading-relaxed">{lang.about.subtitle}</p>
    </div>
  </section>

  <section class="pb-20">
    <div class="container mx-auto px-4 max-w-3xl">
      <div class="flex flex-wrap justify-center gap-x-12 gap-y-6 text-center">
        <div>
          <p class="text-3xl font-bold">{tools.length}</p>
          <p class="text-xs text-muted-foreground uppercase tracking-wider">{lang.about.statsTools}</p>
        </div>
        <div>
          <p class="text-3xl font-bold">{categories.length}</p>
          <p class="text-xs text-muted-foreground uppercase tracking-wider">{lang.about.statsCategories}</p>
        </div>
        <div>
          <p class="text-3xl font-bold">{openSourceCount}</p>
          <p class="text-xs text-muted-foreground uppercase tracking-wider">{lang.about.statsOpenSource}</p>
        </div>
        <div>
          <p class="text-3xl font-bold">{freeCount}</p>
          <p class="text-xs text-muted-foreground uppercase tracking-wider">{lang.about.statsFree}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container mx-auto px-4 max-w-2xl">
      <h2 class="text-2xl font-bold mb-6">{lang.about.missionTitle}</h2>
      <div class="space-y-4 text-muted-foreground leading-relaxed">
        <p>{lang.about.missionP1}</p>
        <p>{lang.about.missionP2}</p>
        <p>{lang.about.missionP3}</p>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container mx-auto px-4 max-w-2xl">
      <h2 class="text-2xl font-bold mb-8">{lang.about.reasonsTitle}</h2>
      <div class="space-y-6">
        {reasons.map((reason) => (
          <div class="flex gap-4">
            <div class="size-8 rounded-md bg-muted flex items-center justify-center shrink-0 mt-0.5">
              <Icon name={reason.icon} class="text-muted-foreground" width="16" height="16" />
            </div>
            <div>
              <p class="font-medium text-sm mb-0.5">{reason.title}</p>
              <p class="text-sm text-muted-foreground leading-relaxed">{reason.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="pb-20 text-center">
    <div class="container mx-auto px-4">
      <p class="text-xs text-muted-foreground">{lang.site.developedBy}</p>
      <p class="text-sm font-medium mt-1">Jonathan Guerra</p>
    </div>
  </section>
</BaseLayout>
