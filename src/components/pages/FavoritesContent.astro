---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FavoritesList from '@/components/tools/FavoritesList';
import { getCollection } from 'astro:content';
import type { Locale } from '@/lib/i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'es' } = Astro.props;

const allTools = await getCollection('tools');
---

<BaseLayout 
  title={locale === 'en' ? 'Favorites' : 'Favoritos'} 
  description={locale === 'en' ? 'Your favorite developer tools.' : 'Tus herramientas de desarrollo favoritas.'} 
  {locale}
>
  <section class="relative overflow-hidden py-16 md:py-20 border-b border-border/50">
    <div class="absolute inset-0 bg-grid pointer-events-none opacity-30" />
    <div class="container mx-auto px-4 text-center relative">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        {locale === 'en' ? 'Your Favorites' : 'Tus Favoritos'}
      </h1>
      <p class="text-lg text-muted-foreground">
        {locale === 'en' 
          ? 'Tools you have saved for quick access' 
          : 'Herramientas que has guardado para acceso rápido'}
      </p>
    </div>
  </section>
  
  <section class="py-12">
    <div class="container mx-auto px-4">
      <FavoritesList
        client:load
        tools={allTools.map(t => ({
          id: t.id,
          name: t.data.name,
          description: t.data.description,
          category: t.data.category,
          slug: t.id,
        }))}
        locale={locale}
      />
    </div>
  </section>
</BaseLayout>
