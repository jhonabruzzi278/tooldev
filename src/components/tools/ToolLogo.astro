---
import { getToolLogo } from '@/lib/svgl';
import type { ThemeOptions } from '@/lib/svgl';
import { readdirSync, existsSync } from 'node:fs';

interface Props {
  toolName: string;
  size?: number;
  class?: string;
}

const { toolName, size = 20, class: className } = Astro.props;

const logosDir = 'public/logos';
const localMap: Record<string, string> = {};
if (existsSync(logosDir)) {
  for (const file of readdirSync(logosDir)) {
    if (file.endsWith('.svg')) {
      const name = file.slice(0, -4);
      localMap[name] = `/logos/${encodeURIComponent(file)}`;
    }
  }
}

const localSrc = localMap[toolName];

const logo = localSrc ? null : await getToolLogo(toolName);
const route = logo?.route;
---

{
  localSrc ? (
    <img src={localSrc} alt={toolName} width={size} height={size} class={className || undefined} loading="lazy" decoding="async" />
  ) : route ? (
    typeof route === 'string' ? (
      <img src={route} alt={toolName} width={size} height={size} class={className || undefined} loading="lazy" decoding="async" />
    ) : (
      <>
        <img src={(route as ThemeOptions).light} alt={toolName} width={size} height={size} class={`dark:hidden${className ? ' ' + className : ''}`} loading="lazy" decoding="async" />
        <img src={(route as ThemeOptions).dark} alt={toolName} width={size} height={size} class={`hidden dark:block${className ? ' ' + className : ''}`} loading="lazy" decoding="async" />
      </>
    )
  ) : null
}