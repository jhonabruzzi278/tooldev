---
import { readdirSync, existsSync } from 'node:fs';

interface Props {
  toolName: string;
  size?: number;
  class?: string;
}

const { toolName, size = 20, class: className } = Astro.props;

const logosDir = 'public/logos';
const localMap: Record<string, string> = {};
if (existsSync(logosDir)) {
  for (const file of readdirSync(logosDir)) {
    if (file.endsWith('.svg')) {
      const name = file.slice(0, -4);
      localMap[name] = `/logos/${encodeURIComponent(file)}`;
    }
  }
}

const src = localMap[toolName];
---

{
  src && (
    <img src={src} alt={toolName} width={size} height={size} class={className || undefined} loading="lazy" decoding="async" />
  )
}