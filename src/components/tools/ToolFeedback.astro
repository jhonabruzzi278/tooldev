---
interface Props {
  toolName: string;
  reportLabel?: string;
  feedbackLabel?: string;
}

const { toolName, reportLabel = 'Reportar error', feedbackLabel = 'Enviar feedback' } = Astro.props;
---

<div class="mt-12 pt-8 border-t border-border/50">
  <div class="flex flex-wrap items-center gap-4 text-sm">
    <a
      href="/contact"
      class="inline-flex items-center gap-1.5 text-muted-foreground hover:text-foreground transition-colors"
    >
      <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>
      {reportLabel}
    </a>
    <span class="text-muted-foreground/30">·</span>
    <a
      href="/contact"
      class="inline-flex items-center gap-1.5 text-muted-foreground hover:text-foreground transition-colors"
    >
      <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      {feedbackLabel}
    </a>
  </div>
</div>
