---
export interface UseCase {
  title: string;
  description: string;
}

interface Props {
  cases: UseCase[];
  title?: string;
}

const { cases, title = 'Cuándo usarlo' } = Astro.props;
if (!cases || cases.length === 0) return;
---

<section class="mb-12">
  <h2 class="text-2xl font-bold mb-6">{title}</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {cases.map((c) => (
      <div class="p-5 rounded-xl border border-border/50 bg-muted/10 hover:bg-muted/20 hover:border-primary/20 transition-colors">
        <h3 class="font-semibold text-sm mb-2">{c.title}</h3>
        <p class="text-sm text-muted-foreground leading-relaxed">{c.description}</p>
      </div>
    ))}
  </div>
</section>
