---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Separator } from '@/components/ui/separator';
import ContactForm from '@/components/shared/ContactForm';
---

<BaseLayout title="Contacto" description="¿Tienes una sugerencia, encontraste un error o quieres recomendar una herramienta? Contáctanos.">
  <section class="py-20">
    <div class="container mx-auto px-4 max-w-3xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Contáctanos</h1>
      <p class="text-xl text-muted-foreground">
        ¿Tienes una sugerencia, encontraste un error o quieres recomendar una herramienta?
        <br />Nos encantaría escucharte.
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold mb-6">Información de contacto</h2>
          <div class="space-y-4">
            <div>
              <p class="font-medium">Correo principal</p>
              <a href="mailto:contacto@tooldev.dev" class="text-primary hover:underline">contacto@tooldev.dev</a>
            </div>
            <div>
              <p class="font-medium">Tiempo de respuesta</p>
              <p class="text-muted-foreground">24 a 48 horas</p>
            </div>
            <div>
              <p class="font-medium">Ubicación</p>
              <p class="text-muted-foreground">Equipo remoto</p>
            </div>
          </div>

          <Separator class="my-8" />

          <h3 class="text-lg font-bold mb-4">Otros medios de contacto</h3>
          <div class="space-y-3">
            <div>
              <p class="text-sm font-medium">Consultas generales</p>
              <a href="mailto:info@tooldev.dev" class="text-sm text-primary hover:underline">info@tooldev.dev</a>
            </div>
            <div>
              <p class="text-sm font-medium">Privacidad</p>
              <a href="mailto:privacy@tooldev.dev" class="text-sm text-primary hover:underline">privacy@tooldev.dev</a>
            </div>
            <div>
              <p class="text-sm font-medium">Asuntos legales</p>
              <a href="mailto:legal@tooldev.dev" class="text-sm text-primary hover:underline">legal@tooldev.dev</a>
            </div>
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold mb-6">Envíanos un mensaje</h2>
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
