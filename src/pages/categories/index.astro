---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Card, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { categories } from '@/lib/categories';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');

const categoriesWithCount = categories.map((cat) => ({
  ...cat,
  count: tools.filter((t) => t.data.category === cat.slug).length,
}));
---

<BaseLayout title="Categorías" description="Explora herramientas para desarrolladores organizadas por categoría.">
  <section class="py-12">
    <div class="container mx-auto px-4">
      <div class="mb-8">
        <h1 class="text-4xl font-bold mb-4">Categorías</h1>
        <p class="text-muted-foreground text-lg">
          Encuentra herramientas por área de especialización
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {categoriesWithCount.map((cat) => (
          <a href={`/categories/${cat.slug}`}>
            <Card class="h-full hover:shadow-lg transition-shadow cursor-pointer">
              <CardHeader>
                <CardTitle class="text-2xl">{cat.name}</CardTitle>
                <CardDescription>{cat.description}</CardDescription>
                <p class="text-sm font-medium text-primary mt-3">
                  {cat.count} {cat.count === 1 ? 'herramienta' : 'herramientas'}
                </p>
              </CardHeader>
            </Card>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
