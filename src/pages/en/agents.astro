---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { Badge } from '@/components/ui/badge';

const agents = [
  {
    id: 'claude',
    name: 'Claude',
    maker: 'Anthropic',
    description: "AI assistant with advanced reasoning, code analysis, writing and precise long-form responses.",
    icon: 'tabler:brain',
    color: '#D97706',
    tags: ['code', 'analysis', 'writing'],
    installCmd: 'npx tooldev-skills install claude',
    docsUrl: 'https://docs.anthropic.com',
    available: false,
  },
  {
    id: 'kiro',
    name: 'Kiro',
    maker: 'Amazon Web Services',
    description: 'AI-powered IDE for spec-driven development. Automatically generates requirements, design and tasks.',
    icon: 'tabler:rocket',
    color: '#6366F1',
    tags: ['ide', 'specs', 'tasks'],
    installCmd: 'npx tooldev-skills install kiro',
    docsUrl: 'https://kiro.dev',
    available: false,
  },
  {
    id: 'cursor',
    name: 'Cursor',
    maker: 'Cursor',
    description: 'AI-first code editor that understands your entire codebase. Best for refactoring and code generation.',
    icon: 'tabler:cursor-text',
    color: '#10B981',
    tags: ['editor', 'code', 'refactor'],
    installCmd: 'npx tooldev-skills install cursor',
    docsUrl: 'https://cursor.sh',
    available: false,
  },
  {
    id: 'codex',
    name: 'Codex',
    maker: 'OpenAI',
    description: "OpenAI's coding agent that can complete full engineering tasks in a secure sandbox environment.",
    icon: 'tabler:code',
    color: '#059669',
    tags: ['code', 'agent', 'automation'],
    installCmd: 'npx tooldev-skills install codex',
    docsUrl: 'https://openai.com/codex',
    available: false,
  },
  {
    id: 'copilot',
    name: 'GitHub Copilot',
    maker: 'GitHub',
    description: 'Code assistant integrated in VS Code and GitHub. Inline suggestions, chat and pull request summaries.',
    icon: 'tabler:git-branch',
    color: '#8B5CF6',
    tags: ['vscode', 'suggestions', 'github'],
    installCmd: 'npx tooldev-skills install github-copilot',
    docsUrl: 'https://github.com/features/copilot',
    available: false,
  },
  {
    id: 'gemini',
    name: 'Gemini',
    maker: 'Google',
    description: "Google's multimodal model. Great for image analysis, code, large documents and complex tasks.",
    icon: 'tabler:sparkles',
    color: '#4285F4',
    tags: ['multimodal', 'analysis', 'google'],
    installCmd: 'npx tooldev-skills install gemini',
    docsUrl: 'https://gemini.google.com',
    available: false,
  },
];
---

<BaseLayout
  title="AI Agents"
  description="Install AI agent skills in your project. Setup guides for Claude, Kiro, Cursor, Codex, Copilot and more."
  locale="en"
>
  <section class="relative overflow-hidden py-16 md:py-20 border-b border-border/50">
    <div class="absolute inset-0 bg-grid pointer-events-none opacity-30" />
    <div class="container mx-auto px-4 text-center relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-medium mb-4">
        <Icon name="tabler:robot" width="14" height="14" class="text-current" />
        AI Agents
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Install tool knowledge<br class="hidden md:block" />
        <span class="text-primary">into your favorite agent</span>
      </h1>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        Each agent can use ToolDev skills to better understand the tools you work with.
        Install with a single command.
      </p>
    </div>
  </section>

  <section class="py-10 border-b border-border/50 bg-muted/20">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground mb-4 text-center">How it works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="flex flex-col items-center text-center gap-2 p-4">
          <div class="size-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-lg">1</div>
          <p class="text-sm font-medium">Choose your agent</p>
          <p class="text-xs text-muted-foreground">Pick the AI assistant you use daily</p>
        </div>
        <div class="flex flex-col items-center text-center gap-2 p-4">
          <div class="size-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-lg">2</div>
          <p class="text-sm font-medium">Copy the command</p>
          <p class="text-xs text-muted-foreground">Run the npx command at your project root</p>
        </div>
        <div class="flex flex-col items-center text-center gap-2 p-4">
          <div class="size-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-lg">3</div>
          <p class="text-sm font-medium">Your agent learns</p>
          <p class="text-xs text-muted-foreground">The SKILL.md file installs to .agents/skills/ and your agent detects it automatically</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold">Available agents</h2>
        <Badge variant="secondary" class="text-xs">{agents.length} agents</Badge>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {agents.map((agent) => (
          <div class="group relative flex flex-col p-5 rounded-xl border border-border/50 bg-card hover:shadow-md hover:border-primary/30 transition-all duration-300">
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-center gap-3">
                <div class="size-10 rounded-xl flex items-center justify-center" style={`background: ${agent.color}15; border: 1px solid ${agent.color}30`}>
                  <Icon name={agent.icon} class="text-current" width="20" height="20" style={`color: ${agent.color}`} />
                </div>
                <div>
                  <h3 class="font-semibold text-sm">{agent.name}</h3>
                  <p class="text-[11px] text-muted-foreground">{agent.maker}</p>
                </div>
              </div>
              {agent.available ? (
                <Badge class="text-[10px] bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border-emerald-500/20">Available</Badge>
              ) : (
                <Badge variant="secondary" class="text-[10px]">Coming soon</Badge>
              )}
            </div>
            <p class="text-xs text-muted-foreground leading-relaxed mb-3 flex-1">{agent.description}</p>
            <div class="flex flex-wrap gap-1 mb-4">
              {agent.tags.map((tag) => (
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-muted text-muted-foreground">{tag}</span>
              ))}
            </div>
            <div class="flex items-center gap-0 rounded-lg border border-border/60 bg-muted/30 overflow-hidden text-xs font-mono mb-3">
              <div class="flex items-center gap-1.5 px-2.5 py-2 border-r border-border/60 shrink-0">
                <Icon name="tabler:terminal-2" width="12" height="12" class="text-emerald-500" />
              </div>
              <span class="flex-1 px-2.5 py-2 text-foreground/70 truncate select-all">{agent.installCmd}</span>
            </div>
            <div class="flex gap-2">
              <a href={agent.docsUrl} target="_blank" rel="noopener noreferrer"
                class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg border border-border/60 text-xs text-muted-foreground hover:text-foreground hover:border-border transition-colors">
                <Icon name="tabler:external-link" width="12" height="12" class="text-current" />
                Docs
              </a>
              <a href="/en/skills"
                class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg bg-primary/10 border border-primary/20 text-xs text-primary hover:bg-primary/20 transition-colors">
                <Icon name="tabler:info-circle" width="12" height="12" class="text-current" />
                How to install
              </a>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-12 p-6 rounded-xl border border-border/50 bg-muted/20 text-center">
        <Icon name="tabler:bulb" width="28" height="28" class="text-primary mx-auto mb-2" />
        <h3 class="font-semibold mb-1">Using a different agent?</h3>
        <p class="text-sm text-muted-foreground mb-4">
          ToolDev skills are standard markdown files compatible with any agent that supports the SKILL.md format.
        </p>
        <a href="/en/skills"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-primary text-primary-foreground text-sm font-medium hover:opacity-90 transition-opacity">
          <Icon name="tabler:terminal-2" width="16" height="16" class="text-current" />
          See how to install skills
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
