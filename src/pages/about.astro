---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Card, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Separator } from '@/components/ui/separator';
import { getCollection } from 'astro:content';
import { categories } from '@/lib/categories';

const tools = await getCollection('tools');
const openSourceCount = tools.filter((t) => t.data.openSource).length;
const freeCount = tools.filter((t) => t.data.pricing === 'gratis' || t.data.pricing === 'open-source').length;

const stats = [
  { value: tools.length, label: 'Herramientas' },
  { value: categories.length, label: 'Categorías' },
  { value: openSourceCount, label: 'Open Source' },
  { value: freeCount, label: 'Gratuitas' },
];

const reasons = [
  { title: 'Curación real', description: 'Cada herramienta es seleccionada y analizada manualmente, no agregamos contenido de forma automática.' },
  { title: 'Explicaciones prácticas', description: 'No solo describimos, explicamos cuándo usar y cuándo evitar cada herramienta.' },
  { title: 'Alternativas útiles', description: 'Incluimos alternativas reales para que puedas comparar y elegir la mejor opción.' },
  { title: 'Enfoque para desarrolladores', description: 'Contenido pensado por y para desarrolladores, sin relleno ni marketing.' },
  { title: 'Contenido en español', description: 'Todo el contenido está escrito originalmente en español para la comunidad hispanohablante.' },
];
---

<BaseLayout title="Acerca de" description="Conoce ToolDev, tu referencia en español para descubrir y elegir mejores herramientas para desarrollo.">
  <section class="py-20">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Acerca de ToolDev</h1>
      <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
        Tu referencia en español para descubrir y elegir mejores herramientas para desarrollo.
      </p>
    </div>
  </section>

  <section class="py-12 bg-muted/50">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map((stat) => (
          <div class="text-center">
            <p class="text-4xl font-bold text-primary">{stat.value}</p>
            <p class="text-sm text-muted-foreground mt-1">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold mb-6">Nuestra misión</h2>
      <p class="text-lg text-muted-foreground mb-4">
        El problema actual no es la falta de herramientas, sino el exceso de opciones sin contexto.
        Cada semana aparecen nuevas librerías, frameworks y servicios que prometen ser la solución definitiva.
      </p>
      <p class="text-lg text-muted-foreground mb-4">
        ToolDev existe para ayudar a los desarrolladores a tomar mejores decisiones técnicas.
        No solo listamos herramientas: explicamos qué son, para qué sirven, cuándo usarlas y cuándo evitarlas.
      </p>
      <p class="text-lg text-muted-foreground">
        Nuestro objetivo es construir una referencia confiable en español sobre herramientas para desarrolladores.
      </p>
    </div>
  </section>

  <Separator />

  <section class="py-16">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-3xl font-bold mb-8 text-center">¿Por qué elegir ToolDev?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {reasons.map((reason) => (
          <Card>
            <CardHeader>
              <CardTitle>{reason.title}</CardTitle>
              <CardDescription>{reason.description}</CardDescription>
            </CardHeader>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <Separator />

  <section class="py-16 text-center">
    <div class="container mx-auto px-4">
      <p class="text-lg text-muted-foreground">
        Desarrollado por <span class="font-semibold text-foreground">Jonathan Guerra</span>
      </p>
    </div>
  </section>
</BaseLayout>
